// Nextflow configuration file

// Manifest
manifest {
    name = 'ACMG Analysis Pipeline'
    author = 'Busra Darendeli'
    description = 'Comprehensive analysis pipeline for ACMG variant classification tools'
    version = '1.0.0'
    nextflowVersion = '>=21.04.0'
}

// Default parameters
params {
    // Input/Output
    input_dir = null
    outdir = 'results'
    
    // Analysis parameters
    datasets = null
    tools = 'Genebe,Franklin,BIAS,TAPES,InterVar_2018,InterVar_2025,DiabloACMG,Exomiser,AutoGVP,VIP-HL,CharGer_Local,CharGer_Online,CPSR,ClinPred'
    
    // Help
    help = false
}

// Process configuration
process {
    // Default resources
    cpus = 1
    memory = '4 GB'
    time = '1h'
    
    // Error strategy
    errorStrategy = 'retry'
    maxRetries = 2
    
    // Container (optional - can be enabled later)
    // container = 'acmg-analysis:latest'
}

// Executor configuration
executor {
    name = 'local'
    cpus = 4
    memory = '16 GB'
}

// Report configuration
report {
    enabled = true
    file = "${params.outdir}/pipeline_report.html"
}

timeline {
    enabled = true
    file = "${params.outdir}/timeline.html"
}

trace {
    enabled = true
    file = "${params.outdir}/trace.txt"
}

// Profiles
profiles {
    standard {
        process.executor = 'local'
    }
    
    slurm {
        process {
            executor = 'slurm'
            queue = 'normal'
            clusterOptions = '--qos=normal'
        }
    }
    
    docker {
        docker.enabled = true
        process.container = 'acmg-analysis:latest'
    }
    
    singularity {
        singularity.enabled = true
        process.container = 'acmg-analysis.sif'
    }
}
